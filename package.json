{
  "name": "beerxml-ts",
  "version": "0.1.0",
  "description": "TypeScript library for parsing and serializing BeerXML 1.0 format",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "example": "tsx example.ts",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "beerxml",
    "beer",
    "brewing",
    "recipe",
    "xml",
    "parser",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.4",
    "fast-xml-parser": "^4.3.3",
    "tsup": "^8.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "zod": "^3.22.4"
  }
}
